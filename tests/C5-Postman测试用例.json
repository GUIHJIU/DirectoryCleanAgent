    {
      "name": "3. 报告导出 — CSV",
      "item": [
        {
          "name": "3.1 导出 CSV — 验证格式规范",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const csv = pm.response.text();",
                  "",
                  "pm.test('返回 200 且 Content-Type 为 text/csv', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv');",
                  "});",
                  "",
                  "pm.test('CSV 以 UTF-8 BOM 开头', () => {",
                  "  const bom = csv.substring(0, 1);",
                  "  // UTF-8 BOM = \\uFEFF",
                  "  pm.expect(csv.charCodeAt(0)).to.equal(0xFEFF);",
                  "});",
                  "",
                  "pm.test('CSV 首行为英文字段名', () => {",
                  "  const headerLine = csv.split('\\n')[0].replace(/^\\uFEFF/, '');",
                  "  const expectedHeaders = 'FilePath,SizeBytes,LastWriteTime,Extension,SemanticCategory,FinalAction,RuleVerdict,AiLabel,AiConfidence';",
                  "  pm.expect(headerLine.trim()).to.equal(expectedHeaders);",
                  "});",
                  "",
                  "pm.test('CSV 每行列数与表头一致', () => {",
                  "  const lines = csv.trim().split('\\n');",
                  "  const headerCount = lines[0].split(',').length;",
                  "  lines.slice(1).forEach((line, i) => {",
                  "    if (line.trim()) {",
                  "      // 注意：引号内的逗号不算分隔符",
                  "      const fields = parseCsvLine(line);",
                  "      pm.expect(fields.length).to.equal(headerCount, `第 ${i + 2} 行列数不匹配`);",
                  "    }",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// CSV 行解析辅助函数（处理引号内的逗号）",
                  "function parseCsvLine(line) {",
                  "  const result = [];",
                  "  let current = '';",
                  "  let inQuotes = false;",
                  "  for (let i = 0; i < line.length; i++) {",
                  "    const ch = line[i];",
                  "    if (inQuotes) {",
                  "      if (ch === '\"') {",
                  "        if (i + 1 < line.length && line[i + 1] === '\"') {",
                  "          current += '\"';",
                  "          i++;",
                  "        } else {",
                  "          inQuotes = false;",
                  "        }",
                  "      } else {",
                  "        current += ch;",
                  "      }",
                  "    } else {",
                  "      if (ch === '\"') {",
                  "        inQuotes = true;",
                  "      } else if (ch === ',') {",
                  "        result.push(current);",
                  "        current = '';",
                  "      } else {",
                  "        current += ch;",
                  "      }",
                  "    }",
                  "  }",
                  "  result.push(current);",
                  "  return result;",
                  "}",
                  "pm.globals.set('parseCsvLine', parseCsvLine);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"Csv\",\n  \"includeProtectedFiles\": false,\n  \"language\": \"zh-CN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/report/export",
              "host": ["http://localhost:5000"],
              "path": ["api", "report", "export"]
            },
            "description": "导出 CSV 报告 — 验证 UTF-8 BOM、列头正确性、每行列数一致。"
          }
        },
        {
          "name": "3.2 导出 CSV — 中文路径转义",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const csv = pm.response.text();",
                  "",
                  "pm.test('CSV 包含正确转义的中文路径', () => {",
                  "  const lines = csv.split('\\n').filter(l => l.trim());",
                  "  pm.expect(lines.length).to.be.at.least(2);",
                  "",
                  "  // 检查是否有包含中文路径的行",
                  "  const chineseLine = lines.find(l => /[\\u4e00-\\u9fff]/.test(l));",
                  "  if (chineseLine) {",
                  "    // 包含逗号的中文路径应被引号包裹",
                  "    const firstField = chineseLine.split(',')[0];",
                  "    // 如果中文字段包含特殊字符，应当被引用",
                  "    pm.expect(chineseLine).to.be.a('string');",
                  "  }",
                  "});",
                  "",
                  "pm.test('CSV 中 FinalAction 为零基数字枚举值', () => {",
                  "  const lines = csv.trim().split('\\n');",
                  "  const headerIndex = lines[0].split(',').indexOf('FinalAction');",
                  "  lines.slice(1, Math.min(lines.length, 20)).forEach(line => {",
                  "    const fields = parseCsvLineForTest(line);",
                  "    if (fields.length > headerIndex) {",
                  "      const action = parseInt(fields[headerIndex], 10);",
                  "      pm.expect(action).to.be.within(0, 3); // AutoDelete=0..Protected=3",
                  "    }",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"Csv\",\n  \"includeProtectedFiles\": false,\n  \"language\": \"zh-CN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/report/export",
              "host": ["http://localhost:5000"],
              "path": ["api", "report", "export"]
            },
            "description": "验证 CSV 中中文路径的转义处理、枚举值的正确序列化。"
          }
        }
      ]
    },
    {
      "name": "4. 端到端流程",
      "item": [
        {
          "name": "4.1 完整流程：模拟 → 导出 HTML → 导出 CSV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 第一步：模拟运行",
                  "const simResponse = pm.response.json();",
                  "",
                  "pm.test('E2E-1: 模拟运行成功', () => {",
                  "  pm.expect(simResponse).to.have.property('operationId');",
                  "  pm.expect(simResponse.totalProcessedCount).to.be.at.least(0);",
                  "});",
                  "",
                  "// 保存 operationId 供后续导出使用",
                  "pm.environment.set('simulationOperationId', simResponse.operationId);",
                  "pm.environment.set('simulationTotalProcessed', simResponse.totalProcessedCount);",
                  "",
                  "// 验证导出接口需要正确的 simulationId",
                  "pm.test('E2E-2: 模拟后导出不应返回 no-simulation-data 错误', () => {",
                  "  // 此测试在后续导出请求中验证",
                  "  pm.expect(simResponse.operationId).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queryParams\": {\n    \"volumes\": [\"C:\"]\n  },\n  \"aiEnabled\": false,\n  \"aiTrustLevel\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/simulation/run-and-export",
              "host": ["http://localhost:5000"],
              "path": ["api", "simulation", "run-and-export"]
            },
            "description": "端到端测试 — 模拟运行后自动生成 HTML 和 CSV 报告。验证完整数据流。"
          }
        }
      ]
    },

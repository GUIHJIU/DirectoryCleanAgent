                  "pm.test('HTML 包含操作分布区域', () => {",
                  "  pm.expect(html).to.include('自动删除');",
                  "  pm.expect(html).to.include('建议删除');",
                  "  pm.expect(html).to.include('需人工确认');",
                  "  pm.expect(html).to.include('已保护');",
                  "});",
                  "",
                  "pm.test('HTML 包含分组明细表格', () => {",
                  "  pm.expect(html).to.include('<table>');",
                  "  pm.expect(html).to.include('</table>');",
                  "});",
                  "",
                  "pm.test('HTML 尾部包含生成时间戳', () => {",

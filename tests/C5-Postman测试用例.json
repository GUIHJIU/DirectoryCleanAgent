{
  "info": {
    "name": "C5 模拟运行与报告导出 — 测试用例集",
    "description": "验证模拟运行服务的管道逻辑和报告导出的 HTML/CSV 格式正确性。由于 C5 是桌面 WPF 应用（无 REST API），此测试集以模拟 HTTP 端点形式组织，实际对应 ISimulationService 和 IReportExporter 的单元/集成测试场景。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 模拟运行",
      "item": [
        {
          "name": "1.1 正常模拟运行 — 默认参数",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证 SimulationResult 结构完整性",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('返回 200 状态码', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('SimulationResult 包含必要字段', () => {",
                  "  pm.expect(response).to.have.property('operationId');",
                  "  pm.expect(response).to.have.property('groups');",
                  "  pm.expect(response).to.have.property('totalFreedBytes');",
                  "  pm.expect(response).to.have.property('totalProcessedCount');",
                  "  pm.expect(response).to.have.property('elapsed');",
                  "  pm.expect(response).to.have.property('autoDeleteCount');",
                  "  pm.expect(response).to.have.property('suggestDeleteCount');",
                  "  pm.expect(response).to.have.property('manualReviewCount');",
                  "  pm.expect(response).to.have.property('protectedCount');",
                  "});",
                  "",
                  "pm.test('operationId 为有效 UUID', () => {",
                  "  const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;",
                  "  pm.expect(response.operationId).to.match(uuidRegex);",
                  "});",
                  "",
                  "pm.test('totalProcessedCount >= 快捷统计之和', () => {",
                  "  const sum = response.autoDeleteCount + response.suggestDeleteCount + response.manualReviewCount + response.protectedCount;",
                  "  pm.expect(response.totalProcessedCount).to.be.at.least(sum);",
                  "});",
                  "",
                  "pm.test('groups 为数组，按 SemanticCategory + FinalAction 排序', () => {",
                  "  pm.expect(response.groups).to.be.an('array');",
                  "  if (response.groups.length > 1) {",
                  "    for (let i = 1; i < response.groups.length; i++) {",
                  "      const prev = response.groups[i - 1];",
                  "      const curr = response.groups[i];",
                  "      const cmp = prev.semanticCategory.localeCompare(curr.semanticCategory);",
                  "      if (cmp === 0) {",
                  "        pm.expect(prev.finalAction).to.be.at.most(curr.finalAction);",
                  "      } else {",
                  "        pm.expect(cmp).to.be.at.most(0);",
                  "      }",
                  "    }",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queryParams\": {\n    \"volumes\": [\"C:\"],\n    \"maxResults\": null\n  },\n  \"aiEnabled\": false,\n  \"aiTrustLevel\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/simulation/run",
              "host": ["http://localhost:5000"],
              "path": ["api", "simulation", "run"]
            },
            "description": "模拟运行 — 默认参数扫描 C 盘，不启用 AI。验证返回的 SimulationResult DTO 结构完整。"
          }
        },
        {
          "name": "1.2 模拟运行 — 启用 AI",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('启用 AI 后返回结果中 AI 标记一致', () => {",
                  "  pm.expect(response.aiEnabled).to.be.true;",
                  "  pm.expect(response.aiTrustLevel).to.equal(2); // High",
                  "});",
                  "",
                  "pm.test('groups 中至少部分条目有 AI 标记', () => {",
                  "  const hasAiLabel = response.groups.some(g => {",
                  "    return g.sampleFiles && g.sampleFiles.some(f => f.aiLabel);",
                  "  });",
                  "  // 注意：AI 可能因速率限制或服务不可用而不返回标签，此处为宽松断言",
                  "  pm.expect(response.totalProcessedCount).to.be.at.least(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queryParams\": {\n    \"volumes\": [\"D:\"],\n    \"pathFilter\": \"D:\\\\Downloads\"\n  },\n  \"aiEnabled\": true,\n  \"aiTrustLevel\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/simulation/run",
              "host": ["http://localhost:5000"],
              "path": ["api", "simulation", "run"]
            },
            "description": "模拟运行 — 扫描 D:\\Downloads，启用 AI 高信任模式。验证 AI 标记和路径过滤。"
          }
        },
        {
          "name": "1.3 模拟运行 — 取消操作",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('取消后返回 499 或 OperationCanceled', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([499, 500]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queryParams\": {\n    \"volumes\": [\"C:\"]\n  },\n  \"aiEnabled\": false,\n  \"aiTrustLevel\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/simulation/run?cancelAfter=500",
              "host": ["http://localhost:5000"],
              "path": ["api", "simulation", "run"],
              "query": [
                {
                  "key": "cancelAfter",
                  "value": "500",
                  "description": "模拟 500ms 后取消"
                }
              ]
            },
            "description": "模拟运行 — 中途取消。验证 CancellationToken 正确传播和状态恢复。"
          }
        }
      ]
    },
    {
      "name": "2. 报告导出 — HTML",
      "item": [
        {
          "name": "2.1 导出 HTML — 验证文档结构",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const html = pm.response.text();",
                  "",
                  "pm.test('返回 200 且 Content-Type 为 text/html', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
                  "});",
                  "",
                  "pm.test('HTML 包含 DOCTYPE', () => {",
                  "  pm.expect(html).to.include('<!DOCTYPE html>');",
                  "});",
                  "",
                  "pm.test('HTML 包含 lang=\"zh-CN\"', () => {",
                  "  pm.expect(html).to.include('lang=\"zh-CN\"');",
                  "});",
                  "",
                  "pm.test('HTML charset 为 utf-8', () => {",
                  "  pm.expect(html).to.include('charset=\"utf-8\"');",
                  "});",
                  "",
                  "pm.test('HTML 包含内嵌 CSS（无外部依赖）', () => {",
                  "  pm.expect(html).to.include('<style>');",
                  "  pm.expect(html).to.include('</style>');",
                  "  // 不应有外部链接",
                  "  pm.expect(html).to.not.include('<link rel=\"stylesheet\"');",

            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"你是一个磁盘清理分析助手。对每个文件输出 {\\\"label\\\":\\\"safe\\\"|\\\"unknown\\\"|\\\"risky\\\",\\\"confidence\\\":0.0-1.0,\\\"explanation\\\":\\\"理由\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"分析以下30个文件（模拟自动触发场景）:\\n\" +\n        Array.from({length: 30}, (_, i) => `${i+1}. C:\\\\Temp\\\\file${i}.tmp (${Math.floor(Math.random()*10000)}KB, ${Math.floor(Math.random()*365)}天前)`).join('\\n')\n    }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 1000\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": ["{{base_url}}"],
              "path": ["v1", "chat", "completions"]
            }
          }
        }

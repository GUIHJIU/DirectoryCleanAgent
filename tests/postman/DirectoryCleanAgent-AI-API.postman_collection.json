{
  "info": {
    "name": "DirectoryCleanAgent AI API 集成测试",
    "description": "智能磁盘清理工具 AI 顾问模块 API 集成测试集合\n对应任务: D1.5 搭建性能与集成测试环境\n覆盖场景: 连接测试 / 单文件分析 / 批量分析 / 错误处理 / 边界条件",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "directorycleanagent-d1.5"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}",
      "type": "string"
    },
    {
      "key": "model",
      "value": "{{model}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. 连接测试",
      "description": "验证 AI API 端点可达性和认证配置",
      "item": [
        {
          "name": "连接测试 — 基础连通性",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证 HTTP 200 响应",
                  "pm.test(\"HTTP 状态码为 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应包含 choices 数组",
                  "pm.test(\"响应包含 choices 数组\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.choices).to.be.an('array');",
                  "    pm.expect(jsonData.choices.length).to.be.above(0);",
                  "});",
                  "",
                  "// 验证 choices[0].message.content 存在",
                  "pm.test(\"响应包含有效的消息内容\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.choices[0].message.content).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"你是一个磁盘清理分析助手。分析文件元数据，输出JSON格式结果。\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"请回复 {\\\"label\\\": \\\"safe\\\", \\\"confidence\\\": 0.95, \\\"explanation\\\": \\\"连接测试通过\\\"}\"\n    }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 200\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": ["{{base_url}}"],
              "path": ["v1", "chat", "completions"]
            }
          }
        },
        {
          "name": "连接测试 — 无效 API Key (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"HTTP 状态码为 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-key-test" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"test\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": ["{{base_url}}"],
              "path": ["v1", "chat", "completions"]
            }
          }
        }
      ]
    },
    {
      "name": "2. 文件分析",
      "description": "单文件与批量文件 AI 分析请求",
      "item": [
        {
          "name": "分析单个文件 — 临时文件 (.tmp)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"HTTP 状态码为 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"响应包含 label 字段 (safe/unknown/risky)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var content = jsonData.choices[0].message.content;",
                  "    // 尝试解析 JSON 内容",
                  "    try {",
                  "        var parsed = JSON.parse(content);",
                  "        pm.expect(['safe', 'unknown', 'risky']).to.include(parsed.label);",
                  "        pm.environment.set(\"last_label\", parsed.label);",
                  "        pm.environment.set(\"last_confidence\", parsed.confidence);",
                  "    } catch(e) {",
                  "        // 如果不是 JSON，检查是否包含 label 关键字",
                  "        pm.expect(content).to.be.a('string');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"你是一个磁盘清理分析助手。对于每个文件，输出JSON: {\\\"label\\\": \\\"safe\\\"|\\\"unknown\\\"|\\\"risky\\\", \\\"confidence\\\": 0.0-1.0, \\\"explanation\\\": \\\"简短原因\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"分析以下文件:\\n- 路径: C:\\\\Windows\\\\Temp\\\\debug_20260101.log\\n- 大小: 15.2 MB\\n- 修改时间: 2026-01-01\\n- 扩展名: .log\"\n    }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 200\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": ["{{base_url}}"],
              "path": ["v1", "chat", "completions"]
            }
          }

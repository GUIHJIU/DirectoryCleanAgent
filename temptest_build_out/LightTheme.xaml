<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         浅色主题 — 颜色定义。
         覆盖 CommonStyles 中引用的动态资源键值。
    ============================================================ -->

    <!-- 窗口/主背景色 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF" />

    <!-- 顶部栏 -->
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TopBarForegroundBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="#E0E0E0" />

    <!-- 仪表板卡片 -->
    <SolidColorBrush x:Key="CardTextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="CardTextSecondaryBrush" Color="#666666" />

    <!-- 操作栏 -->
    <SolidColorBrush x:Key="ActionBarBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="ActionBarBorderBrush" Color="#E8E8E8" />

    <!-- 操作栏按钮 -->
    <SolidColorBrush x:Key="ActionButtonBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="ActionButtonForegroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#1976D2" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#1565C0" />
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#E53935" />
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DisabledButtonBackgroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="DisabledButtonForegroundBrush" Color="#AAAAAA" />

    <!-- 状态栏 -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#666666" />
    <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#E0E0E0" />

    <!-- 进度条 -->
    <SolidColorBrush x:Key="ProgressBarFillBrush" Color="#1976D2" />
    <SolidColorBrush x:Key="ProgressBarTrackBrush" Color="#E0E0E0" />

    <!-- 警告横幅 -->
    <SolidColorBrush x:Key="WarningBannerBackgroundBrush" Color="#FFF8E1" />
    <SolidColorBrush x:Key="WarningBannerForegroundBrush" Color="#E65100" />
    <SolidColorBrush x:Key="WarningBannerBorderBrush" Color="#FFB300" />

    <!-- 主内容区占位 -->
    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#AAAAAA" />

    <!-- C2: 文件列表与分组视图 -->
    <SolidColorBrush x:Key="SplitterBackgroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="TreeViewBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="TreeViewItemHoverBrush" Color="#E8E8E8" />
    <SolidColorBrush x:Key="TreeViewItemSelectedBrush" Color="#D0D0F0" />
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="#E3F2FD" />
    <SolidColorBrush x:Key="HintTextForegroundBrush" Color="#999999" />

</ResourceDictionary>

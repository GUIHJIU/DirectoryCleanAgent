<UserControl x:Class="DirectoryCleanAgent.Controls.WarningBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters"
             Height="36">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <!-- 黄色警告横幅：非管理员只读模式 / 索引未完成时显示 -->
    <Border x:Name="BannerBorder"
            Background="{StaticResource WarningBannerBackgroundBrush}"
            BorderBrush="{StaticResource WarningBannerBorderBrush}"
            BorderThickness="0,0,0,1"
            Visibility="{Binding ShowWarningBanner, Converter={StaticResource BoolToVisibility}}"
            CornerRadius="0">

        <Grid Margin="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 警告图标 -->
            <TextBlock Grid.Column="0" Text="⚠️" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,8,0" />

            <!-- 警告文本 -->
            <TextBlock Grid.Column="1" Text="{Binding WarningMessage}"
                       FontSize="13" Foreground="{StaticResource WarningBannerForegroundBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</UserControl>

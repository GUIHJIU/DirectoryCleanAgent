<UserControl x:Class="DirectoryCleanAgent.Controls.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:DirectoryCleanAgent.Models"
             xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters">

    <UserControl.Resources>
        <!-- 值转换器注册 -->
        <converters:SemanticCategoryToIconConverter x:Key="SemanticCategoryToIconConverter" />
        <converters:FinalActionToDisplayConverter x:Key="FinalActionToDisplayConverter" />
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:FilePathToDisplayConverter x:Key="FilePathToDisplayConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:DepthToFontWeightConverter x:Key="DepthToFontWeightConverter" />
    </UserControl.Resources>

    <!-- ============================================================
         主布局：分组树 [260px] | 分割线 [4px] | 文件列表 [*]
    ============================================================ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!-- ============================================================
             Column 0: 左侧分组树 + 底部提示
        ============================================================ -->
        <Border Grid.Column="0" Background="{StaticResource TreeViewBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- TreeView 分组树 -->
                <TreeView Grid.Row="0"
                          x:Name="GroupTreeView"
                          ItemsSource="{Binding GroupTree}"
                          Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVisibilityConverter}}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          BorderThickness="0"
                          Background="Transparent"
                          Padding="4,2">
                    <TreeView.Resources>
                        <!-- HierarchicalDataTemplate: 递归渲染 FileGroupNode 及其子节点 -->
                        <HierarchicalDataTemplate DataType="{x:Type models:FileGroupNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2,3">
                                <!-- 分组图标 -->
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <!-- 标签 + 统计 -->
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="13"
                                               FontWeight="{Binding Depth, Converter={StaticResource DepthToFontWeightConverter}}" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CountText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextForegroundBrush}" />
                                        <TextBlock Text=" · "
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextForegroundBrush}" />
                                        <TextBlock Text="{Binding SizeText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextForegroundBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>

                    <!-- TreeViewItem 容器样式 -->
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            <Setter Property="Padding" Value="4,2" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <StackPanel>
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="3">
                                                <ContentPresenter x:Name="PART_Header"
                                                                  ContentSource="Header"
                                                                  HorizontalAlignment="Stretch" />
                                            </Border>
                                            <ItemsPresenter x:Name="ItemsHost"
                                                            Visibility="Collapsed"
                                                            Margin="16,0,0,0" />
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource TreeViewItemSelectedBrush}" />
                                            </Trigger>
                                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource TreeViewItemHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- 底部灰色提示文字 -->
                <Border Grid.Row="1" Padding="12,6" BorderBrush="{StaticResource ActionBarBorderBrush}" BorderThickness="0,1,0,0">
                    <TextBlock Text="{Binding BottomHintText}"
                               Visibility="{Binding ShowBottomHint, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{StaticResource HintTextForegroundBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================
             Column 1: GridSplitter 分割线
        ============================================================ -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource SplitterBackgroundBrush}"
                      ResizeBehavior="PreviousAndNext"
                      Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- ============================================================
             Column 2: 右侧文件列表 DataGrid
        ============================================================ -->
        <Border Grid.Column="2" Background="{StaticResource ContentBackgroundBrush}">
            <Grid>
                <!-- Loading 遮罩 -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- 空状态 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource PlaceholderForegroundBrush}" />
                    <TextBlock Text="{Binding EmptyMessage}"
                               FontSize="15"
                               Foreground="{StaticResource PlaceholderForegroundBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>

                <!-- DataGrid 文件列表 -->
                <DataGrid ItemsSource="{Binding CurrentFileList}"
                          Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          Sorting="DataGrid_Sorting"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True"
                          ScrollViewer.IsDeferredScrollingEnabled="True"
                          Background="{StaticResource ContentBackgroundBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{StaticResource TreeViewBackgroundBrush}"
                          BorderThickness="0"
                          Style="{StaticResource FileListDataGridStyle}">

                    <DataGrid.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="🤖 AI 分析此文件"
                                      Command="{Binding RequestAiAnalysisCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="🤖 AI 分析所有勾选文件"
                                      Command="{Binding AnalyzeSelectedFilesCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Resources>
                        <!-- 列头排序事件绑定 -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="{StaticResource DataGridHeaderBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CardTextSecondaryBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="BorderThickness" Value="0,1,0,1" />
                            <Setter Property="BorderBrush" Value="{StaticResource ActionBarBorderBrush}" />
                        </Style>

                        <!-- 数据行样式 -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="32" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource DataGridRowHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource DataGridRowSelectedBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- 单元格样式 -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        </Style>

                        <Style TargetType="DataGridColumnHeader" x:Key="RightAlignedColumnHeaderStyle">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!-- Column 0: 复选框 -->
                        <DataGridCheckBoxColumn Header="☑"
                                                Width="40"
                                                Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                                IsReadOnly="False" />

                        <!-- Column 1: 语义标签图标 + 文本 -->
                        <DataGridTemplateColumn Header="语义标签" Width="140"
                                                SortMemberPath="SemanticCategory">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SemanticCategoryIcon}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding SemanticCategory}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Column 2: 文件名 -->
                        <DataGridTextColumn Header="文件名" Width="*"
                                            Binding="{Binding FilePath}"
                                            SortMemberPath="Name">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Setter Property="ToolTip" Value="{Binding FullPath}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Column 3: 大小 -->
                        <DataGridTextColumn Header="大小" Width="100"
                                            Binding="{Binding SizeText}"
                                            SortMemberPath="Size">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Column 4: 修改日期 -->
                        <DataGridTextColumn Header="修改日期" Width="140"
                                            Binding="{Binding LastWriteTimeText}"
                                            SortMemberPath="DateModified" />

                        <!-- Column 5: 类型（扩展名） -->
                        <DataGridTextColumn Header="类型" Width="90"
                                            Binding="{Binding Extension}"
                                            SortMemberPath="Extension" />

                        <!-- Column 6: AI 状态 -->
                        <DataGridTemplateColumn Header="AI" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Cursor="Hand"
                                                ToolTip="{Binding AiExplanation}">
                                        <TextBlock Text="{Binding AiStatusIcon}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding AiStatusText}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource CardTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Column 7: 操作建议 -->
                        <DataGridTemplateColumn Header="操作建议" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2"
                                            ToolTip="{Binding FinalActionText}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FinalAction}" Value="0">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FinalAction}" Value="1">
                                                        <Setter Property="Background" Value="#E3F2FD" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FinalAction}" Value="2">
                                                        <Setter Property="Background" Value="#FFF3E0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FinalAction}" Value="3">
                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding FinalAction, Converter={StaticResource FinalActionToDisplayConverter}}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

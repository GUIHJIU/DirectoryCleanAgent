<UserControl x:Class="DirectoryCleanAgent.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters"
             xmlns:ViewModels="clr-namespace:DirectoryCleanAgent.ViewModels"
             Loaded="AuditLogView_Loaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <!-- ============================================================
         审计日志视图布局：过滤栏 / DataGrid / 分页导航
    ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: 过滤栏 -->
            <RowDefinition Height="*" />     <!-- Row 1: DataGrid -->
            <RowDefinition Height="Auto" />  <!-- Row 2: 分页导航 -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Row 0: 过滤栏 — 日期范围 / 操作类型 / 用户 / 按钮
        ============================================================ -->
        <Border Grid.Row="0" Padding="12,10"
                Background="{StaticResource ActionBarBackgroundBrush}"
                BorderBrush="{StaticResource ActionBarBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 起始时间 -->
                <TextBlock Text="起始:" VerticalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CardTextSecondaryBrush}" Margin="0,0,4,0" />
                <DatePicker Width="140" SelectedDate="{Binding Filter.From}"
                            FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />

                <!-- 截止时间 -->
                <TextBlock Text="截止:" VerticalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CardTextSecondaryBrush}" Margin="0,0,4,0" />
                <DatePicker Width="140" SelectedDate="{Binding Filter.To}"
                            FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />

                <!-- 分隔 -->
                <Separator Width="1" Height="20"
                           VerticalAlignment="Center" Margin="4,0,12,0" />

                <!-- 操作类型下拉 -->
                <TextBlock Text="操作:" VerticalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CardTextSecondaryBrush}" Margin="0,0,4,0" />
                <ComboBox Width="140" FontSize="13" VerticalAlignment="Center"
                          ItemsSource="{x:Static ViewModels:AuditLogViewModel.OperationTypes}"
                          SelectedItem="{Binding Filter.OperationType}" Margin="0,0,12,0" />

                <!-- 用户 SID -->
                <TextBlock Text="用户:" VerticalAlignment="Center" FontSize="13"
                           Foreground="{StaticResource CardTextSecondaryBrush}" Margin="0,0,4,0" />
                <TextBox Width="160" FontSize="13" VerticalAlignment="Center"
                         Text="{Binding Filter.UserSid, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="输入用户 SID 或账户名进行筛选" Margin="0,0,8,0" />

                <!-- 搜索按钮 -->
                <Button Content="🔍 搜索" Height="30" Width="80"
                        FontSize="13" Cursor="Hand" Margin="8,0,4,0"
                        Command="{Binding SearchCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource PrimaryButtonBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PrimaryButtonForegroundBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBorderBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 重置过滤按钮 -->
                <Button Content="重置" Height="30" Width="60"
                        FontSize="13" Cursor="Hand" Margin="4,0,0,0"
                        Background="{StaticResource ActionButtonBackgroundBrush}"
                        Foreground="{StaticResource ActionButtonForegroundBrush}"
                        Command="{Binding ResetFilterCommand}" />
            </StackPanel>
        </Border>

        <!-- ============================================================
             Row 1: 审计日志 DataGrid（虚拟化，不可编辑）
        ============================================================ -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  ScrollViewer.IsDeferredScrollingEnabled="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  BorderThickness="0"
                  RowHeight="28"
                  Background="{StaticResource ContentBackgroundBrush}">

            <DataGrid.Columns>
                <!-- 时间列 -->
                <DataGridTemplateColumn Header="时间" Width="160" SortMemberPath="TimestampText">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TimestampText}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0" FontFamily="Consolas" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 用户列 -->
                <DataGridTemplateColumn Header="用户" Width="160" SortMemberPath="UserDisplay">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UserDisplay}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 操作类型列 -->
                <DataGridTemplateColumn Header="操作类型" Width="140" SortMemberPath="OperationType">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding OperationType}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0"
                                       FontFamily="Consolas" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 目标列 -->
                <DataGridTemplateColumn Header="目标" Width="220" SortMemberPath="Target">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Target}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Target}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 结果列 -->
                <DataGridTemplateColumn Header="结果" Width="80" SortMemberPath="Result">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Result}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0" FontWeight="SemiBold"
                                       Foreground="{Binding Result, Converter={x:Static converters:ResultToColorConverter.Instance}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 详情列（截断+ToolTip） -->
                <DataGridTemplateColumn Header="详情" Width="*" SortMemberPath="DetailsSummary">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DetailsSummary}" VerticalAlignment="Center"
                                       FontSize="12" Margin="8,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding DetailsFull}"
                                       Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Foreground="{StaticResource CardTextSecondaryBrush}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 空状态提示（无数据时居中显示） -->
        <TextBlock Grid.Row="1"
                   Text="{Binding EmptyMessage}"
                   FontSize="16" Foreground="{StaticResource CardTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- 加载中指示器 -->
        <TextBlock Grid.Row="1"
                   Text="正在加载审计日志..."
                   FontSize="14" Foreground="{StaticResource CardTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- ============================================================
             Row 2: 分页导航栏
        ============================================================ -->
        <Border Grid.Row="2" Padding="12,8"
                Background="{StaticResource ActionBarBackgroundBrush}"
                BorderBrush="{StaticResource ActionBarBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 上一页 -->
                <Button Grid.Column="0" Content="◀ 上一页" Height="28" Width="80"
                        FontSize="12" Cursor="Hand"
                        Command="{Binding PrevPageCommand}"
                        IsEnabled="{Binding CanGoPrevPage}" />

                <!-- 页数信息 -->
                <TextBlock Grid.Column="1" FontSize="13" Margin="16,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource CardTextPrimaryBrush}"
                           Text="{Binding PageInfoText}" />

                <!-- 填充空间 -->

                <!-- 下一页 -->
                <Button Grid.Column="3" Content="下一页 ▶" Height="28" Width="80"
                        FontSize="12" Cursor="Hand"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNextPage}" />

                <!-- 每页条数提示 -->
                <TextBlock Grid.Column="4" FontSize="11" Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource CardTextSecondaryBrush}"
                           Text="每页 50 条" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

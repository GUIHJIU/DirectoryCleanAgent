<Window x:Class="DirectoryCleanAgent.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters"
        Title="智能磁盘清理 — 首次配置向导" Height="560" Width="720"
        MinHeight="500" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="SetupWizardWindow_Loaded"
        Closing="SetupWizardWindow_Closing">

    <!-- ============================================================
         主布局：步骤指示器 + 内容区 + 导航按钮
    ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 步骤指示器 -->
            <RowDefinition Height="*" />     <!-- 步骤内容 -->
            <RowDefinition Height="Auto" />  <!-- 导航按钮 -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             Row 0: 步骤指示器
        ============================================================ -->
        <Border Grid.Row="0" Padding="24,16" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <ItemsControl x:Name="StepIndicatorList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <Grid Width="28" Height="28" Margin="0,0,8,0">
                                <Ellipse x:Name="StepCircle" Fill="#E0E0E0"
                                         Width="28" Height="28" />
                                <TextBlock Text="{Binding Index}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#333333" />
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="#888888" MaxWidth="120"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Text=" → " FontSize="14" Foreground="#CCCCCC"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="{Binding Converter={x:Static converters:BoolToVisibilityConverter.Instance}}" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ============================================================
             Row 1: 步骤内容区 — 由代码后台动态切换
        ============================================================ -->
        <Border Grid.Row="1" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ContentControl x:Name="StepContentHost" Margin="40,30" />
            </ScrollViewer>
        </Border>

        <!-- ============================================================
             Row 2: 底部导航按钮
        ============================================================ -->
        <Border Grid.Row="2" Padding="24,14" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：跳过此步骤 -->
                <Button Grid.Column="0" x:Name="SkipStepButton"
                        Content="跳过此步骤" Width="110" Height="34" FontSize="13"
                        Cursor="Hand" Click="SkipCurrentStep_Click" />

                <!-- 上一步 -->
                <Button Grid.Column="1" x:Name="PreviousButton"
                        Content="← 上一步" Width="100" Height="34" FontSize="13"
                        Cursor="Hand" Click="PreviousStep_Click" Margin="0,0,8,0" />

                <!-- 下一步 / 完成 / 跳过向导 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="NextButton"
                            Content="下一步 →" Width="120" Height="34" FontSize="13"
                            Background="#0078D4" Foreground="White"
                            Cursor="Hand" Click="NextStep_Click" Margin="0,0,8,0" />
                    <Button x:Name="SkipWizardButton"
                            Content="跳过向导" Width="100" Height="34" FontSize="13"
                            Cursor="Hand" Click="SkipWizard_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

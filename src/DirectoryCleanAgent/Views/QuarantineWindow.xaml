<Window x:Class="DirectoryCleanAgent.Views.QuarantineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters"
        Title="隔离区管理" Height="600" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Loaded="QuarantineWindow_Loaded"
        Closing="QuarantineWindow_Closing">

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </Window.Resources>

    <!-- 主布局：内容区 + 底部操作栏 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 主内容区 — 容量信息栏 + DataGrid 文件列表 -->
        <Border Grid.Row="0" Padding="20"
                Background="{StaticResource WindowBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ============================================================
                     顶部：容量信息栏 — 使用率进度条 + 统计文本
                ============================================================ -->
                <Border Grid.Row="0" Padding="16,12" Margin="0,0,0,12"
                        Background="{StaticResource ContentBackgroundBrush}"
                        CornerRadius="6"
                        BorderBrush="{StaticResource ActionBarBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 容量标题 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="隔离区容量" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource CardTextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="  —  " FontSize="13"
                                       Foreground="{StaticResource CardTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CapacityText}" FontSize="13"
                                       Foreground="{StaticResource CardTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=" (" FontSize="13"
                                       Foreground="{StaticResource CardTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UtilizationText}" FontSize="13"
                                       Foreground="{StaticResource CardTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=")" FontSize="13"
                                       Foreground="{StaticResource CardTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- 过期提示 -->
                        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12"
                                   Foreground="{StaticResource WarningBannerForegroundBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding ExpiredFileCount, Mode=OneWay}" />
                            <Run Text=" 个文件已过期" />
                        </TextBlock>

                        <!-- 使用率进度条 -->
                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                     Height="8" Minimum="0" Maximum="100"
                                     Value="{Binding UtilizationPercentage, Mode=OneWay}"
                                     Foreground="{StaticResource ProgressBarFillBrush}"
                                     Background="{StaticResource ProgressBarTrackBrush}" />
                    </Grid>
                </Border>

                <!-- ============================================================
                     错误/禁用提示（隔离区禁用时显示）
                ============================================================ -->
                <Border Grid.Row="0" Padding="12" Margin="0,0,0,12"
                        Background="{StaticResource WarningBannerBackgroundBrush}"
                        BorderBrush="{StaticResource WarningBannerBorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                               Foreground="{StaticResource WarningBannerForegroundBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- ============================================================
                     C9: 只读模式警告横幅（非管理员启动时显示）
                ============================================================ -->
                <Border Grid.Row="0" Padding="12" Margin="0,0,0,12"
                        Background="#FFF8E1"
                        BorderBrush="#FFB300"
                        BorderThickness="1" CornerRadius="4"
                        Visibility="{Binding ShowReadOnlyWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding ReadOnlyWarningMessage}"
                                   FontSize="13" Foreground="#E65100"
                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ============================================================
                     DataGrid 文件列表
                ============================================================ -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding QuarantineFiles}"
                          Style="{StaticResource FileListDataGridStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0">

                    <DataGrid.Columns>
                        <!-- CheckBox 列：多选 -->
                        <DataGridCheckBoxColumn Header=""
                                               Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                               Width="36"
                                               IsThreeState="False" />

                        <!-- 原始文件名 -->
                        <DataGridTextColumn Header="原始文件名"
                                           Binding="{Binding OriginalFileName}"
                                           Width="220">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 文件大小 -->
                        <DataGridTextColumn Header="大小"
                                           Binding="{Binding FileSizeText}"
                                           Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 隔离时间 -->
                        <DataGridTextColumn Header="隔离时间"
                                           Binding="{Binding QuarantineTimestampText}"
                                           Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- SHA256 前缀 -->
                        <DataGridTextColumn Header="SHA256 前缀"
                                           Binding="{Binding Sha256Prefix}"
                                           Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontFamily" Value="Consolas" />
                                    <Setter Property="FontSize" Value="11" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 过期状态 -->
                        <DataGridTextColumn Header="状态"
                                           Binding="{Binding ExpiredStatusText}"
                                           Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ============================================================
             Row 1: 底部操作栏 — 选中统计 + 操作按钮 + 进度条
        ============================================================ -->
        <Border Grid.Row="1" Padding="16,8"
                Background="{StaticResource ActionBarBackgroundBrush}"
                BorderBrush="{StaticResource ActionBarBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 选中状态文本 -->
                <TextBlock Grid.Column="0" Text="{Binding SelectionText}" FontSize="12"
                           Foreground="{StaticResource StatusBarForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0" />

                <!-- 全选 CheckBox -->
                <CheckBox Grid.Column="1" Content="全选"
                          VerticalAlignment="Center" FontSize="12"
                          Foreground="{StaticResource CardTextSecondaryBrush}"
                          Command="{Binding SelectAllCommand}"
                          CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=IsChecked}" />

                <!-- 操作按钮组（右侧对齐） -->
                <!-- 恢复选中按钮（主操作） -->
                <Button Grid.Column="3" Content="恢复选中"
                        Style="{StaticResource ActionBarButtonStyle}"
                        Command="{Binding RestoreSelectedCommand}"
                        ToolTip="将选中的文件恢复到原始路径"
                        Background="{StaticResource PrimaryButtonBackgroundBrush}"
                        Foreground="{StaticResource PrimaryButtonForegroundBrush}"
                        BorderBrush="{StaticResource PrimaryButtonBorderBrush}" />

                <!-- 永久删除按钮（危险操作） -->
                <Button Grid.Column="4" Content="永久删除"
                        Style="{StaticResource ActionBarButtonStyle}"
                        Command="{Binding DeleteSelectedCommand}"
                        ToolTip="永久删除选中的文件（不可撤销）"
                        Background="{StaticResource DangerButtonBackgroundBrush}"
                        Foreground="{StaticResource DangerButtonForegroundBrush}" />

                <!-- 进度条（操作进行中显示） -->
                <ProgressBar Grid.Column="5"
                             Style="{StaticResource StatusBarProgressBarStyle}"
                             Width="120"
                             Value="{Binding OperationProgress.Percentage}"
                             Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- 取消按钮（操作进行中显示） -->
                <Button Grid.Column="6" Content="✕ 取消"
                        Width="60" Height="30" FontSize="12"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibilityConverter}}"
                        Cursor="Hand" Background="#FFF3E0" Foreground="#E65100" />
            </Grid>
        </Border>
    </Grid>
</Window>

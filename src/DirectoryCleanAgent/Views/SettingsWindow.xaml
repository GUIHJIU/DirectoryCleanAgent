<Window x:Class="DirectoryCleanAgent.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DirectoryCleanAgent.Converters"
        xmlns:models="clr-namespace:DirectoryCleanAgent.Models"
        Title="设置" Height="620" Width="820"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Loaded="SettingsWindow_Loaded"
        Closing="SettingsWindow_Closing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Window.Resources>

    <!-- ============================================================
         主布局：TabControl + 底部按钮栏
    ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============================================================
             TabControl — 五个标签页
        ============================================================ -->
        <TabControl Grid.Row="0" Margin="12,12,12,0"
                    Background="{StaticResource WindowBackgroundBrush}">

            <!-- ========================================================
                 Tab 1: 通用
            ======================================================== -->
            <TabItem Header="{Binding LblTabGeneral}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,16">
                    <StackPanel>
                        <!-- 启动行为 -->
                        <TextBlock Text="{Binding LblStartupBehavior}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding StartupBehaviorOptions}"
                                  SelectedValue="{Binding EditStartupBehavior}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="32" Width="280"
                                  HorizontalAlignment="Left" Margin="0,0,0,20" />

                        <!-- 主题 -->
                        <TextBlock Text="{Binding LblTheme}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding ThemeOptions}"
                                  SelectedValue="{Binding EditTheme}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="32" Width="280"
                                  HorizontalAlignment="Left" Margin="0,0,0,20" />

                        <!-- 语言 -->
                        <TextBlock Text="{Binding LblLanguage}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedValue="{Binding EditLanguage}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="32" Width="280"
                                  HorizontalAlignment="Left" Margin="0,0,0,20" />

                        <!-- 数据存储路径 -->
                        <TextBlock Text="{Binding LblDataPath}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="440" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditDataStoragePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" VerticalContentAlignment="Center" Padding="8,0"
                                     FontSize="12" />
                            <Button Grid.Column="1" Content="浏览..."
                                    Width="80" Height="32"
                                    Margin="8,0,0,0"
                                    Command="{Binding BrowseDataPathCommand}" />
                        </Grid>
                        <TextBlock Text="默认: %LocalAppData%\\SpaceClear"
                                   FontSize="11" Foreground="#999999" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========================================================
                 Tab 2: 扫描与清理
            ======================================================== -->
            <TabItem Header="{Binding LblTabScanClean}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,16">
                    <StackPanel>
                        <!-- 扫描模式 -->
                        <TextBlock Text="{Binding LblScanMode}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding ScanModeOptions}"
                                  SelectedValue="{Binding EditScanMode}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="32" Width="320"
                                  HorizontalAlignment="Left" Margin="0,0,0,20" />

                        <!-- 删除方式 -->
                        <TextBlock Text="{Binding LblDeleteMethod}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding DeleteMethodOptions}"
                                  SelectedValue="{Binding EditDeleteMethod}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="32" Width="320"
                                  HorizontalAlignment="Left" Margin="0,0,0,20" />

                        <!-- 复选框组 -->
                        <CheckBox Content="一键清理前弹出二次确认"
                                  IsChecked="{Binding EditConfirmBeforeClean}"
                                  Margin="0,0,0,12" FontSize="13" Foreground="#333333" />
                        <CheckBox Content="显示需人工审核的文件"
                                  IsChecked="{Binding EditShowManualReview}"
                                  Margin="0,0,0,12" FontSize="13" Foreground="#333333" />
                        <CheckBox Content="自动刷新扫描结果（Everything 事件驱动）"
                                  IsChecked="{Binding EditAutoRefresh}"
                                  Margin="0,0,0,20" FontSize="13" Foreground="#333333" />

                        <!-- 包含的磁盘卷 -->
                        <TextBlock Text="{Binding LblIncludedVolumes}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="仅 NTFS 卷可被 Everything 索引，非 NTFS 卷不会显示在列表中。"
                                   FontSize="11" Foreground="#999999" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding IncludedVolumes}"
                                      Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsIncluded}"
                                              Margin="0,3" FontSize="13" Foreground="#444444" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 若没有发现 NTFS 卷 -->
                        <TextBlock Text="未检测到 NTFS 格式的固定磁盘卷。请检查磁盘格式。"
                                   FontSize="12" Foreground="#D13438"
                                   Visibility="{Binding IncludedVolumes.Count, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========================================================
                 Tab 3: AI 顾问
            ======================================================== -->
            <TabItem Header="{Binding LblTabAI}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,16">
                    <StackPanel>
                        <!-- 启用开关 -->
                        <CheckBox Content="启用 AI 智能顾问"
                                  IsChecked="{Binding EditAIEnabled}"
                                  Margin="0,0,0,20" FontSize="14" FontWeight="SemiBold"
                                  Foreground="#333333" />

                        <!-- AI 配置表单（启用后才可编辑） -->
                        <StackPanel IsEnabled="{Binding EditAIEnabled}">
                            <!-- 服务类型 -->
                            <TextBlock Text="{Binding LblAIServiceType}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AIServiceTypeOptions}"
                                      SelectedValue="{Binding EditAIServiceType}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Display"
                                      Height="32" Width="280"
                                      HorizontalAlignment="Left" Margin="0,0,0,16" />

                            <!-- API URL -->
                            <TextBlock Text="{Binding LblAIApiUrl}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding EditAIApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Width="440"
                                     HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Margin="0,0,0,16" FontSize="12" />

                            <!-- API Key（PasswordBox 不可直接绑定，代码后台处理） -->
                            <TextBlock Text="{Binding LblAIApiKey}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <PasswordBox x:Name="AIApiKeyBox"
                                         Height="32" Width="440"
                                         HorizontalAlignment="Left"
                                         PasswordChanged="AIApiKeyBox_PasswordChanged"
                                         Margin="0,0,0,16" FontSize="12" />

                            <!-- 模型名称 -->
                            <TextBlock Text="{Binding LblAIModel}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding EditAIModel, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Width="280"
                                     HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Margin="0,0,0,16" FontSize="12" />

                            <!-- 信任等级 -->
                            <TextBlock Text="{Binding LblAITrustLevel}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AITrustLevelOptions}"
                                      SelectedValue="{Binding EditAITrustLevel}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Display"
                                      Height="32" Width="200"
                                      HorizontalAlignment="Left" Margin="0,0,0,16" />

                            <!-- 每日限额 -->
                            <TextBlock Text="{Binding LblAIDailyLimit}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding EditAIDailyLimit, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" Width="120"
                                     HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Margin="0,0,0,16" FontSize="12"
                                     PreviewTextInput="NumericOnly_PreviewTextInput" />

                            <!-- 自动分析（仅专家模式） -->
                            <CheckBox Content="自动为未分类文件请求 AI 分析（仅专家模式生效）"
                                      IsChecked="{Binding EditAIAutoAnalyze}"
                                      Margin="0,8,0,0" FontSize="13" Foreground="#555555" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ========================================================
                 Tab 4: 自动化清理（禁用 — 即将推出）
            ======================================================== -->
            <TabItem Header="{Binding LblTabAutomation}" IsEnabled="False">
                <Grid Background="#FAFAFA">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🚧" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,16" />
                        <TextBlock Text="{Binding LblAutomationComingSoon}"
                                   FontSize="22" Foreground="#AAAAAA"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="自动化定时清理功能正在规划中，将在后续版本中提供。"
                                   FontSize="14" Foreground="#BBBBBB"
                                   HorizontalAlignment="Center" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========================================================
                 Tab 5: 排除与保护
            ======================================================== -->
            <TabItem Header="{Binding LblTabExclusion}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,16">
                    <StackPanel>
                        <!-- 自动保护目录（只读） -->
                        <TextBlock Text="{Binding LblProtectedDirs}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <Border Background="#F5F5F5" CornerRadius="4" Padding="14"
                                Margin="0,0,0,20">
                            <ItemsControl ItemsSource="{Binding ProtectedDirs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="🛡️ " Foreground="#555555"
                                                   FontSize="12" Margin="0,3">
                                            <Run Text="{Binding Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 用户排除目录 -->
                        <TextBlock Text="{Binding LblUserExcludedDirs}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewExcludedDir, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32" VerticalContentAlignment="Center" Padding="8,0"
                                     FontSize="12" />
                            <Button Grid.Column="1" Content="添加" Width="64" Height="32"
                                    Margin="8,0,0,0"
                                    Command="{Binding AddExcludedDirCommand}" />
                        </Grid>
                        <TextBlock Text="支持通配符，如 C:\\Users\\*\\Downloads\\*"
                                   FontSize="11" Foreground="#999999" Margin="0,0,0,10" />

                        <!-- 排除目录列表 -->
                        <ListBox ItemsSource="{Binding UserExcludedDirs}"
                                 Height="100" Margin="0,0,0,20"
                                 BorderBrush="#E0E0E0" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12" Foreground="#444444"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Content="✕"
                                                Width="24" Height="24"
                                                FontSize="11" ToolTip="移除此目录"
                                                Command="{Binding DataContext.RemoveExcludedDirCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 排除文件扩展名 -->
                        <TextBlock Text="{Binding LblExcludedExtensions}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding ExcludedExtensionsText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32" VerticalContentAlignment="Center" Padding="8,0"
                                 FontSize="12" Margin="0,0,0,6" />
                        <TextBlock Text="多个扩展名用逗号分隔，如 .pst, .ost, .vhd"
                                   FontSize="11" Foreground="#999999" Margin="0,0,0,20" />

                        <!-- 隔离区大小 -->
                        <TextBlock Text="{Binding LblQuarantineSize}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding QuarantineSizeValue, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" Height="32"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     Margin="0,0,8,0" FontSize="12"
                                     PreviewTextInput="NumericOnly_PreviewTextInput" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding QuarantineSizeUnitOptions}"
                                      SelectedIndex="{Binding QuarantineSizeUnitIndex}"
                                      DisplayMemberPath="Display"
                                      Width="70" Height="32" />
                        </Grid>
                        <TextBlock Text="默认上限 min(2% 磁盘空间, 10 GB)"
                                   FontSize="11" Foreground="#999999" Margin="0,0,0,20" />

                        <!-- 隔离区保留天数 -->
                        <TextBlock Text="{Binding LblQuarantineRetention}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333333"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditQuarantineRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Height="32"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center" Padding="8,0"
                                 FontSize="12" Margin="0,0,0,6"
                                 PreviewTextInput="NumericOnly_PreviewTextInput" />
                        <TextBlock Text="超过保留天数的隔离文件将被自动清理。"
                                   FontSize="11" Foreground="#999999" Margin="0,0,0,4" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ============================================================
             底部按钮栏
        ============================================================ -->
        <Border Grid.Row="1" Padding="16,10"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：重置按钮 -->
                <Button Grid.Column="0" Content="重置为默认值"
                        Width="120" Height="32" FontSize="13"
                        Command="{Binding ResetToDefaultsCommand}"
                        HorizontalAlignment="Left"
                        ToolTip="将所有设置恢复为默认值" />

                <!-- 右侧：确定 / 取消 / 应用 -->
                <Button Grid.Column="1" Content="{Binding LblBtnOK}"
                        Width="80" Height="32" FontSize="13"
                        IsDefault="True"
                        Command="{Binding OKCommand}"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="{Binding LblBtnCancel}"
                        Width="80" Height="32" FontSize="13"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="{Binding LblBtnApply}"
                        Width="80" Height="32" FontSize="13"
                        Command="{Binding ApplyCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="DirectoryCleanAgent.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DirectoryCleanAgent.Views"
        Title="历史记录" Height="680" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Loaded="HistoryWindow_Loaded">

    <!-- ============================================================
         HistoryWindow — TabControl 容器窗口
         Tab 1: 审计日志（AuditLogView）
         Tab 2: 删除历史（DeletionHistoryView）
    ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TabControl -->
        <TabControl Grid.Row="0" Margin="12,12,12,0"
                    Background="{StaticResource WindowBackgroundBrush}">

            <!-- ========================================================
                 Tab 1: 审计日志
            ======================================================== -->
            <TabItem Header="📋 审计日志">
                <views:AuditLogView DataContext="{Binding AuditLogViewModel}" />
            </TabItem>

            <!-- ========================================================
                 Tab 2: 删除历史
            ======================================================== -->
            <TabItem Header="🗑️ 删除历史">
                <views:DeletionHistoryView DataContext="{Binding DeletionHistoryViewModel}" />
            </TabItem>
        </TabControl>

        <!-- 底部关闭按钮 -->
        <Border Grid.Row="1" Padding="12,10"
                Background="{StaticResource ActionBarBackgroundBrush}"
                BorderBrush="{StaticResource ActionBarBorderBrush}"
                BorderThickness="0,1,0,0">
            <Button Content="关闭" Height="32" Width="80"
                    HorizontalAlignment="Right"
                    FontSize="13" Cursor="Hand"
                    Background="{StaticResource ActionButtonBackgroundBrush}"
                    Foreground="{StaticResource ActionButtonForegroundBrush}"
                    Click="CloseButton_Click" />
        </Border>
    </Grid>
</Window>

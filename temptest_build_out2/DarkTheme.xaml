<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         深色主题 — 颜色定义。
         所有颜色按键名与 LightTheme 一致，仅值不同。
    ============================================================ -->

    <!-- 窗口/主背景色 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#2D2D2D" />

    <!-- 顶部栏 -->
    <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="TopBarForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="#3D3D3D" />

    <!-- 仪表板卡片（深色下使用深色半透明背景，覆盖 FinalActionToColorConverter 的默认色） -->
    <SolidColorBrush x:Key="CardTextPrimaryBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="CardTextSecondaryBrush" Color="#999999" />

    <!-- 操作栏 -->
    <SolidColorBrush x:Key="ActionBarBackgroundBrush" Color="#252525" />
    <SolidColorBrush x:Key="ActionBarBorderBrush" Color="#3D3D3D" />

    <!-- 操作栏按钮 -->
    <SolidColorBrush x:Key="ActionButtonBackgroundBrush" Color="#3D3D3D" />
    <SolidColorBrush x:Key="ActionButtonForegroundBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#555555" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#1565C0" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#1976D2" />
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#C62828" />
    <SolidColorBrush x:Key="DangerButtonForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DisabledButtonBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="DisabledButtonForegroundBrush" Color="#666666" />

    <!-- 状态栏 -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#252525" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#999999" />
    <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#3D3D3D" />

    <!-- 进度条 -->
    <SolidColorBrush x:Key="ProgressBarFillBrush" Color="#42A5F5" />
    <SolidColorBrush x:Key="ProgressBarTrackBrush" Color="#3D3D3D" />

    <!-- 警告横幅（深色下略微降低亮度以保护眼睛） -->
    <SolidColorBrush x:Key="WarningBannerBackgroundBrush" Color="#3E2723" />
    <SolidColorBrush x:Key="WarningBannerForegroundBrush" Color="#FFB74D" />
    <SolidColorBrush x:Key="WarningBannerBorderBrush" Color="#E65100" />

    <!-- 主内容区占位 -->
    <SolidColorBrush x:Key="PlaceholderForegroundBrush" Color="#666666" />

    <!-- C2: 文件列表与分组视图（深色主题） -->
    <SolidColorBrush x:Key="SplitterBackgroundBrush" Color="#3D3D3D" />
    <SolidColorBrush x:Key="TreeViewBackgroundBrush" Color="#252525" />
    <SolidColorBrush x:Key="TreeViewItemHoverBrush" Color="#333333" />
    <SolidColorBrush x:Key="TreeViewItemSelectedBrush" Color="#3D3D5C" />
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="#333333" />
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="#353535" />
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="#1A3A5C" />
    <SolidColorBrush x:Key="HintTextForegroundBrush" Color="#888888" />

</ResourceDictionary>
